# ============================================================
# DisInfo Shield — 環境變數範本
# ============================================================
# 使用方式：
#   1. 複製此檔案：cp .env.example .env
#   2. 填入真實的 Lambda Function URL
#   3. .env 已列入 .gitignore，不會被提交到 Git
#
# ⚠️  VITE_ 前綴是必要的，Vite 只會將此前綴的變數暴露給前端
# ⚠️  絕對不要在程式碼中硬編碼 API URL
# ============================================================

VITE_API_URL=https://your-lambda-url.us-west-2.on.aws/
